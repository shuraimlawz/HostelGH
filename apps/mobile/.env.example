# HostelGH Mobile App - Environment Variables

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# For production, set this to your deployed API URL:
# EXPO_PUBLIC_API_URL=https://api.hostelgh.com/api

# EAS Configuration
EXPO_PUBLIC_EAS_PROJECT_ID=your_eas_project_id_here

# Paystack (for payment processing)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# Environment
EXPO_PUBLIC_ENV=development

# Debug Mode
EXPO_PUBLIC_DEBUG=true
