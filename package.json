{
  "name": "hostel-booking",
  "version": "0.0.1",
  "description": "Hostel Booking System",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "web"
  ],
  "scripts": {
    "build": "npx prisma generate --schema=./prisma/schema.prisma && nest build",
    "postinstall": "npx prisma generate --schema=./prisma/schema.prisma",
    "admin:create": "FORCE_CREATE_ADMIN=true ts-node -r tsconfig-paths/register scripts/create_admin.ts",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "dotenv -e .env.staging -- jest --config ./apps/api/test/jest-e2e.json --runInBand --forceExit",
    "test:e2e:api": "dotenv -e .env.staging -- jest --config ./apps/api/test/jest-e2e.json --runInBand --forceExit",
    "test:e2e:web": "dotenv -e .env.staging -- npx playwright test",
    "test:e2e:live": "dotenv -e .env.production -- jest --config ./apps/api/test/jest-e2e.json --testPathPattern=live-verification --runInBand --forceExit",
    "db:staging:migrate": "dotenv -e .env.staging -- npx prisma migrate deploy",
    "db:staging:seed": "dotenv -e .env.staging -- ts-node -r tsconfig-paths/register prisma/seed-staging.ts",
    "db:staging:reset": "dotenv -e .env.staging -- npx prisma migrate reset --force",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@langchain/openai": "^1.4.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@prisma/config": "^7.4.2",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "claude": "^0.1.1",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.4.2",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "joi": "^18.0.2",
    "langchain": "^1.3.4",
    "meilisearch": "^0.57.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^2.2.1",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.4",
    "@nestjs/schematics": "^11.0.4",
    "@nestjs/testing": "^11.0.9",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cron": "^2.0.1",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.5",
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.8",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.1",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.24.1"
  },
  "overrides": {
    "react-helmet-async": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@angular-devkit/core": "^19.0.0",
    "ajv": "^8.17.1",
    "glob": "^11.0.1",
    "inflight": "0.0.0-unused"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  }
}
