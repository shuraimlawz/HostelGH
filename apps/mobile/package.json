    "react-native-gesture-handler": "^2.16.0",
    "react-native-screens": "^4.0.0",
    "react-native-safe-area-context": "^4.10.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "@tanstack/react-query": "^5.28.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "react-native-svg": "^15.1.0",
    "expo-image": "^1.12.0",
    "expo-linking": "^6.2.0",
    "zod": "^3.22.0",
