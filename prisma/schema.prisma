generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  TENANT
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING_APPROVAL // tenant created, waiting owner action
  APPROVED // owner approved, payment can proceed (or required)
  REJECTED // owner rejected
  CANCELLED // tenant/admin cancelled
  CONFIRMED // payment verified (or marked confirmed)
  CHECKED_IN // tenant has moved in
  CHECKED_OUT // tenant has moved out
  COMPLETED // booking fully finished
  EXPIRED // auto-expired if not paid within window (optional)
}

enum PaymentProvider {
  PAYSTACK
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PayoutMethodType {
  BANK
  MOBILE_MONEY
}

enum RoomGender {
  MALE
  FEMALE
  MIXED
}

enum HostelBookingStatus {
  OPEN // Accepting bookings
  LIMITED // Few slots left
  CLOSED // Not accepting bookings
  FULL // No availability
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String?
  googleId     String?  @unique
  role         UserRole @default(TENANT)

  firstName String?
  lastName  String?

  isActive           Boolean @default(true)
  emailVerified      Boolean @default(false)
  isOnboarded        Boolean @default(true)
  emailNotifications Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  ownedHostels  Hostel[]       @relation("HostelOwner")
  bookings      Booking[]      @relation("BookingTenant")
  refreshTokens RefreshToken[]
  payoutMethods PayoutMethod[]
  savedPaymentMethods SavedPaymentMethod[]
  wallets       Wallet[]
  payoutRequests PayoutRequest[]
  subscriptions  Subscription[]

  paystackSubaccountCode String? // For automated split payments

  @@index([role])
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "MOMO" or "CARD"
  provider  String   // "MTN", "VODAFONE", "AIRTELTIGO" or "VISA", "MASTERCARD"
  phone     String?  // For MOMO
  last4     String?  // For CARD
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PayoutMethod {
  id            String           @id @default(cuid())
  ownerId       String
  type          PayoutMethodType
  provider      String // e.g. "GCB", "MTN"
  accountNumber String
  accountName   String
  bankCode      String? // Needed for Paystack subaccount creation
  isDefault     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String // store hashed refresh token
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Hostel {
  id          String  @id @default(cuid())
  ownerId     String
  name        String
  description String?
  addressLine String
  city        String
  region      String?
  country     String  @default("GH")

  latitude  Float?
  longitude Float?

  images     String[] @default([])
  amenities  String[] @default([])
  university String?

  isFeatured Boolean @default(false)
  featuredUntil DateTime?
  minPrice   Int?

  // Ghana-specific fields
  whatsappNumber    String? // Primary contact method
  distanceToCampus  String? // "10 minutes walk", "5 min trotro"
  utilitiesIncluded String[]            @default([]) // ["water", "light", "gas"]
  bookingStatus     HostelBookingStatus @default(OPEN)

  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User      @relation("HostelOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  rooms    Room[]
  bookings Booking[]
  wallets  Wallet[]

  @@index([ownerId])
  @@index([city])
  @@index([isPublished])
}

model Wallet {
  id        String   @id @default(cuid())
  ownerId   String   @unique
  balance   Int      @default(0) // pesewas
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id])
  hostelId String?
  hostel   Hostel? @relation(fields: [hostelId], references: [id])
}

model PayoutRequest {
  id          String       @id @default(cuid())
  ownerId     String
  amount      Int
  status      PayoutStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  owner User @relation(fields: [ownerId], references: [id])
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Subscription {
  id        String    @id @default(cuid())
  ownerId   String
  plan      String
  active    Boolean   @default(false)
  expiresAt DateTime?

  owner User @relation(fields: [ownerId], references: [id])
}

model Room {
  id           String   @id @default(cuid())
  hostelId     String
  name         String // e.g. "2-in-1", "4-in-1"
  description  String?
  capacity     Int // number of tenants per room
  totalUnits   Int // inventory count of this room type
  pricePerTerm Int // store in minor unit? (e.g. kobo/pesewas) decide in service layer
  images       String[] @default([])

  // Ghana-specific fields
  roomConfiguration String // "1 in a room", "2 in a room", etc.
  gender            RoomGender @default(MIXED)
  totalSlots        Int // Total available slots
  availableSlots    Int // Current availability
  hasAC             Boolean    @default(false)
  utilitiesIncluded String[]   @default([]) // ["water", "light", "gas"]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostel   Hostel        @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  bookings BookingItem[]

  @@index([hostelId])
  @@index([isActive])
  @@index([gender])
}

model Booking {
  id       String        @id @default(cuid())
  hostelId String
  tenantId String
  status   BookingStatus @default(PENDING_APPROVAL)

  // term/time window (customize later)
  startDate DateTime
  endDate   DateTime

  notes     String?
  expiresAt DateTime? // for approval/payment window (optional)

  // Ghana-specific fields
  paymentDeadline DateTime? // 24-hour payment deadline
  autoReleaseAt   DateTime? // When to auto-release if unpaid
  slotNumber      Int? // Assigned slot number

  deletionRequested Boolean @default(false)
  deletionReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostel Hostel @relation(fields: [hostelId], references: [id], onDelete: Restrict)
  tenant User   @relation("BookingTenant", fields: [tenantId], references: [id], onDelete: Restrict)

  items   BookingItem[]
  payment Payment?

  @@index([hostelId])
  @@index([tenantId])
  @@index([status])
  @@index([autoReleaseAt])
}

model BookingItem {
  id        String   @id @default(cuid())
  bookingId String
  roomId    String
  quantity  Int      @default(1) // number of units requested of this room type
  unitPrice Int // price snapshot at time of booking
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([roomId])
}

model Payment {
  id        String          @id @default(cuid())
  bookingId String          @unique
  provider  PaymentProvider @default(PAYSTACK)
  status    PaymentStatus   @default(INITIATED)

  amount        Int // in minor unit
  platformFee   Int @default(0)
  ownerEarnings Int @default(0)
  currency      String @default("GHS")

  // Paystack fields
  reference        String  @unique
  authorizationUrl String?
  accessCode       String?

  paidAt     DateTime?
  rawWebhook Json? // store last webhook payload (optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([provider])
}
