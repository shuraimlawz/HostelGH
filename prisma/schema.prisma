generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TENANT
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  PAYMENT_SECURED
  RESERVED
  CHECKED_IN
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentProvider {
  PAYSTACK
  OFFLINE
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  USSD
  MOBILE_MONEY
}

enum PaymentStatus {
  INITIATED
  PENDING
  AWAITING_VERIFICATION
  SUCCESS
  FAILED
  REFUNDED
}

enum RoomGender {
  MALE
  FEMALE
  MIXED
}

enum UserGender {
  MALE
  FEMALE
  OTHER
}

enum FacilityType {
  FREE
  PAID
}

enum HostelBookingStatus {
  OPEN // Accepting bookings
  LIMITED // Few slots left
  CLOSED // Not accepting bookings
  FULL // No availability
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  ARCHIVED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PENDING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String?
  googleId     String?  @unique
  role         UserRole @default(TENANT)

  firstName  String?
  middleName String?
  lastName   String?
  avatarUrl  String?
  gender     UserGender?

  isActive           Boolean @default(true)
  emailVerified      Boolean @default(false)
  isOnboarded        Boolean @default(true)
  emailNotifications Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Trust & Safety
  isVerified   Boolean @default(false)
  ghanaCardUrl String?
  ghanaCardId  String?

  // Community
  lookingForRoommate    Boolean @default(false)
  roommateMatchingPrefs Json?

  // relations
  ownedHostels  Hostel[]       @relation("HostelOwner")
  favorites     Favorite[]
  bookings      Booking[]      @relation("BookingTenant")
  refreshTokens RefreshToken[]

  subscriptions  Subscription[]
  adminAuditLogs AdminAuditLog[]

  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  reviews                 Review[]
  conversations           Conversation[]
  messages                Message[]
  wallets                 Wallet[]

  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String // store hashed refresh token
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique // Hashed or securely generated random string
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [email], references: [email], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [email], references: [email], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model Hostel {
  id          String  @id @default(cuid())
  ownerId     String
  name        String
  description String?
  addressLine String
  city        String
  region      String?
  country     String  @default("GH")

  latitude  Float?
  longitude Float?

  images     String[] @default([])
  amenities  String[] @default([])
  university String?

  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?
  minPrice      Int?

  // Ghana-specific fields
  whatsappNumber    String? // Primary contact method
  distanceToCampus  String? // "10 minutes walk", "5 min trotro"
  utilitiesIncluded String[]            @default([]) // ["water", "light", "gas"]
  bookingStatus     HostelBookingStatus @default(OPEN)
  policiesText      String?
  genderCategory    RoomGender?

  isPublished         Boolean @default(false)
  isArchived          Boolean @default(false)
  pendingVerification Boolean @default(false) // Awaiting admin review before first publish

  // Trust & Safety
  isVerifiedHostel Boolean @default(false)
  virtualTourUrl   String?

  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User             @relation("HostelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  rooms      Room[]
  facilities HostelFacility[]
  bookings   Booking[]

  reviews   Review[]
  favorites Favorite[]

  @@index([ownerId])
  @@index([city])
  @@index([isPublished])
  @@index([university])
  @@index([averageRating])
  @@index([minPrice])
}

model HostelFacility {
  id        String       @id @default(cuid())
  hostelId  String
  name      String
  type      FacilityType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  hostel Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  planId           String
  status           SubscriptionStatus @default(PENDING)
  startDate        DateTime           @default(now())
  endDate          DateTime?
  paymentReference String?            @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([endDate])
}

model Plan {
  id               String   @id @default(cuid())
  code             String   @unique // FREE, PRO, PREMIUM
  name             String
  description      String?
  monthlyPrice     Int? // pesewas
  yearlyPrice      Int? // pesewas
  listingLimit     Int? // null = unlimited
  featuredIncluded Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions Subscription[]
}

model Room {
  id           String   @id @default(cuid())
  hostelId     String
  name         String // e.g. "2-in-1", "4-in-1"
  description  String?
  capacity     Int // number of tenants per room
  totalUnits   Int // inventory count of this room type
  pricePerTerm Int // store in minor unit? (e.g. kobo/pesewas) decide in service layer
  images       String[] @default([])

  // Ghana-specific fields
  roomConfiguration String // "1 in a room", "2 in a room", etc.
  gender            RoomGender @default(MIXED)
  totalSlots        Int // Total available slots
  availableSlots    Int // Current availability
  hasAC             Boolean    @default(false)
  utilitiesIncluded String[]   @default([]) // ["water", "light", "gas"]

  isActive  Boolean    @default(true)
  status    RoomStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  hostel   Hostel        @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  bookings BookingItem[]

  @@index([hostelId])
  @@index([isActive])
  @@index([gender])
  @@index([pricePerTerm])
  @@index([roomConfiguration])
}

model Booking {
  id       String        @id @default(cuid())
  hostelId String
  tenantId String
  status   BookingStatus @default(PENDING)

  // term/time window (customize later)
  startDate DateTime
  endDate   DateTime

  notes     String?
  expiresAt DateTime? // for approval/payment window (optional)

  // Ghana-specific fields
  paymentDeadline DateTime? // 24-hour payment deadline
  autoReleaseAt   DateTime? // When to auto-release if unpaid
  slotNumber      Int? // Assigned slot number

  // KYC/identity fields
  levelOfStudy     String?
  guardianName     String?
  guardianPhone    String?
  admissionDocUrl  String?
  passportPhotoUrl String?

  deletionRequested Boolean @default(false)
  deletionReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostel Hostel @relation(fields: [hostelId], references: [id], onDelete: Restrict)
  tenant User   @relation("BookingTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  items   BookingItem[]
  payment Payment?

  @@index([hostelId])
  @@index([tenantId])
  @@index([status])
  @@index([autoReleaseAt])
  @@index([createdAt])
  @@index([startDate])
}

model BookingItem {
  id        String   @id @default(cuid())
  bookingId String
  roomId    String
  quantity  Int      @default(1) // number of units requested of this room type
  unitPrice Int // price snapshot at time of booking
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([roomId])
}

model Payment {
  id        String          @id @default(cuid())
  bookingId String          @unique
  provider  PaymentProvider @default(PAYSTACK)
  method    PaymentMethod   @default(CARD)
  status    PaymentStatus   @default(INITIATED)

  amount        Int // in minor unit
  processingFee Int?   @default(0)
  platformFee   Int    @default(0)
  ownerEarnings Int    @default(0)
  currency      String @default("GHS")

  // Paystack fields
  reference        String  @unique
  authorizationUrl String?
  accessCode       String?

  // Bank transfer fields
  bankName      String?
  bankCode      String?
  accountNumber String?
  accountName   String?

  // Mobile Money fields
  momoProvider    String? // MTN, VODAFONE, AIRTELTIGO
  momoPhoneNumber String?

  paidAt          DateTime?
  offlineProofUrl String?
  rawWebhook      Json? // store last webhook payload (optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([provider])
  @@index([method])
}

model AdminAuditLog {
  id         String  @id @default(cuid())
  adminId    String?
  actionType String // CREATE, UPDATE, DELETE, APPROVE, REJECT
  entityType String // USER, HOSTEL, BOOKING, PAYMENT, etc.
  entityId   String?
  details    String? // Human readable summary
  metadata   Json? // Store before/after state
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([entityType])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String?  @unique
  
  // Ratings
  rating      Int      // Overall rating
  cleanliness Int?
  comfort     Int?
  value       Int?
  staff       Int?
  
  comment     String?
  isVerified  Boolean  @default(false)
  isModerated Boolean  @default(false)
  
  tenantId    String
  hostelId    String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        User           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostel        Hostel         @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  photos        ReviewPhoto[]
  ownerResponse OwnerResponse?

  @@index([hostelId])
  @@index([tenantId])
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model OwnerResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  isSupport Boolean  @default(false)
  guestId   String? // For guest-to-admin support chats
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants User[]
  messages     Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String? // Optional for guests
  guestName      String? // Name provided by guest
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  hash      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hash])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  hostelId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostel Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@unique([userId, hostelId])
  @@index([userId])
  @@index([hostelId])
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String
  provider    String // MTN, VODAFONE, AIRTELTIGO
  phoneNumber String
  status      String   @default("active") // active, suspended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, phoneNumber])
  @@index([userId])
}
